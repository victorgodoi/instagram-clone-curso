# Dependências instaladas localmente — serão reinstaladas dentro do container
node_modules

# Build de produção gerado pelo CRA — não faz parte do dev server
build

# Arquivo de log do npm
npm-debug.log*

# Variáveis de ambiente com dados sensíveis (Firebase keys, etc.)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Controle de versão — não precisa estar no container
.git
.gitignore

# Configurações do editor
.vscode
.idea

# Arquivos de sistema do macOS
.DS_Store

# Arquivos Docker em si — não precisam ser copiados para dentro do container
Dockerfile
.dockerignore
docker-compose.yml

# Documentação
*.md
